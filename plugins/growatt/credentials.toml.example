# Credenciales Growatt — copiar a `credentials.toml` (gitignored) y editar.
#
# Estas credenciales son las mismas que usas en https://server.growatt.com/
# El archivo `credentials.toml` está en .gitignore para que NO se versione.
#
# Alternativa segura: ponlo en ~/.config/streamdeb/growatt.toml (fuera del
# repo). El plugin prueba primero esa ruta y cae a esta como fallback.

[growatt]
user = "tu_usuario_growatt"
password = "tu_password_growatt"

# Opcional: si tienes varias plantas, fija una por nombre o ID.
# Si se omite, el plugin usa la primera planta de tu cuenta.
# plant_id = "1234567"
